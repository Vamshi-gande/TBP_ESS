# Application
APP_SECRET_KEY=change-me-in-production-use-long-random-string
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Database (PostgreSQL via Docker — see docker-compose.yml)
DATABASE_URL=postgresql://sentinel:sentinel_secret@localhost:5434/surveillance

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
TWILIO_FROM_SMS=+14155238886
ALERT_PHONE_WHATSAPP=whatsapp:+91XXXXXXXXXX
ALERT_PHONE_SMS=+91XXXXXXXXXX

# AI / Detection
YOLO_MODEL=yolov8n.pt
DETECTION_CONFIDENCE=0.5
LOITERING_THRESHOLD_SECONDS=30

# Storage
STORAGE_BASE=./storage
MAX_CLIP_DURATION_SECONDS=30

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=1440
